eader area (toolbar / file menu). */\n  .lm-Widget.jp-Toolbar.jp-NotebookPanel-toolbar {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n    display: none;\n  }\n\n  .lm-Widget.jp-Toolbar.jp-cell-menu.jp-cell-toolbar {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n  }\n\n  /* The JL cells area. */\n  .lm-Widget.jp-Notebook.jp-mod-scrollPastEnd.jp-NotebookPanel-notebook {\n    width: 100% !important;\n    top: 0 !important;\n    /* This div is getting an inline style with discrete height from JL. */\n    height: auto !important;\n    max-height: 100%;\n    contain: unset !important;\n    background: ",";\n  }\n\n  .cm-scroller {\n    line-height: 20px !important;\n    margin-bottom: 4px;\n    margin-right: -16px;\n    padding-bottom: 4px;\n    display: block;\n  }\n\n  .cm-line.cm-line {\n    caret-color: ",' !important;\n  }\n\n  /* (b/376709824) Fixes visual bug on Safari */\n  .cm-editor > div[aria-live="polite"]:first-of-type {\n    visibility: hidden !important;\n    position: absolute !important;\n    top: unset !important;\n  }\n\n  .cm-content {\n    border-right: 22px solid transparent;\n    && {\n      padding-top: 12px;\n      padding-bottom: 12px;\n    }\n  }\n\n  /* Editor shifts when text overflows to the right, prevent the border from becoming visible. */\n  .cm-focused {\n    && {\n      outline: none;\n    }\n  }\n\n  span.cm-matchingBracket {color: #0b0;}\n  span.cm-nonmatchingBracket {color: #a22;}\n\n  /*\n   * Override JupyterLab\'s default CodeMirror syntax token colors in dark mode.\n   * The bare @jupyterlab/codemirror defaults fail WCAG AA (4.5:1) against our\n   * dark editor background (GREY_850, #2E3033), causing the readability\n   * complaints in b/372462536. Each color below is from our carbon palette and\n   * has been verified to meet 4.5:1 contrast against #2E3033; keeping the\n   * overrides centralized here also insulates us from future JupyterLab\n   * upgrades that change the defaults out from under us.\n   */\n  ',"\n\n  /* Hide dirty marker */\n  .jp-Notebook .jp-Cell.jp-mod-dirty .jp-InputPrompt::before {\n    display: none;\n  }\n\n  /* Hide rename pop up */\n  .Toastify {\n    display: none;\n  }\n\n  /* Hide orange color on run icon */\n  &.jp-Notebook &.jp-Cell.jp-mod-dirty &.jp-InputPrompt {\n    color: ","\n  }\n\n  /* Hide dirty orange background */\n  &.jp-Notebook &.jp-Cell.jp-mod-active.jp-mod-dirty &.jp-Collapser {\n    background-color: ","\n  }\n\n  /* Hide resizer when output scroll is toggled on. */\n  .jp-CodeCell.jp-mod-outputsScrolled .jp-Cell-outputArea {\n    resize: none;\n  }\n\n  /* CodeMirror wrapping element. */\n  .lm-Widget.jp-CodeMirrorEditor.jp-Editor.jp-InputArea-editor {\n    border-radius: 8px;\n    border: 1px solid "," !important;\n  }\n\n  /* Required to make cell button hover state background not clip. */\n  .lm-Widget.jp-InputPrompt.jp-InputArea-prompt {\n    overflow: visible;\n  }\n\n  /**\n   * The next few blocks are used to style the LSP rename symbol\n   * dialog. Unfortunately, the LSP dialogs don't have a custom\n   * class, so these changes would apply to all dialogs inside the\n   * iframe. However, we aren't likely to have any other dialogs\n   * inside the iframe, so this should be fine.\n   */\n  .lm-Widget.lm-Panel.jp-Dialog-content {\n    border-radius: 20px;\n    font-family: Inter, sans-serif;\n    min-width: 500px;\n    padding: 32px;\n    resize: none;\n    background-color: ",";\n  }\n\n  .lm-Widget.jp-Dialog-header {\n    font-size: 32px;\n    font-weight: 700;\n    color: ",";\n  }\n\n  .lm-Widget.lm-Panel {\n    top: 0px !important;\n  }\n\n  /* jp-mod-styled = the input element for getting the new name */\n  .lm-Widget.jp-Input-Dialog.jp-Dialog-body > .jp-mod-styled {\n    background-color: transparent;\n    border-radius: 4px;\n    box-shadow: none;\n    height: 40px;\n    margin: 8px 0 32px 0;\n    border-color: ",";\n    &:hover {\n      border-color: ",";\n    }\n    &:focus {\n      border-color: ",";\n    }\n  }\n\n  .lm-Widget.jp-Dialog-footer > .jp-Dialog-button {\n    font-size: 14px;\n    font-weight: 700;\n    height: 36px;\n    letter-spacing: normal;\n    margin: 0;\n    outline: none;\n    padding: 0 24px;\n  }\n\n  .lm-Widget.jp-Dialog-footer > .jp-Dialog-button.jp-mod-reject {\n    background-color: transparent;\n    color: ",";\n    &:hover {\n      background-color: ",";\n    }\n  }\n\n  .lm-Widget.jp-Dialog-footer > .jp-Dialog-button.jp-mod-accept {\n    background-color: ",";\n    color: ",";\n  }\n\n  /* TODO tiff: get the hover card to show up */\n  /** Fixes styling nit on documentation hover card:\n      https://screenshot.googleplex.com/66xtLHMmnPi6gAX */\n   .lsp-signature-help > .jp-Tooltip-content * {\n    background-color: ",';\n  }\n\n  /* JupyterLab adds too much padding to end of the page, which we do not\n     want. */\n  .jp-Notebook.jp-mod-scrollPastEnd::after {\n    /* TODO(b/227634919): Add enough space to the bottom of the notebook to let\n       users click "+ Code" / "+ Markdown" actions when the snackbar is visible\n       to avoid b/196609396. We should revisit when we\'re using the global page\n       snackbar instead, which may not have this issue. */\n    min-height: 128px;\n  }\n\n  \n  .jp-Notebook, .jp-MainAreaWidget {\n    ',";\n  }\n\n  .lm-Widget.lm-Panel.lm-SplitPanel-child #main-panel {\n    contain: unset !important;\n  }\n\n  /* Scripts require fixed position spanning full width / height. */\n  "," .cm-editor {\n    position: fixed !important;\n    left: 0;\n    top: 0;\n    width: 100vw;\n    max-width: 100vw;\n    height: 100vh;\n    max-height: 100vh;\n    z-index: 999999;\n    /* Ensures padding doesn't push scrollbars out of view. */\n    box-sizing: border-box;\n    overflow: auto;\n  }\n  /** (b/377925647) Makes the iFrame background viewable when in different modes. */\n  .jp-RenderedHTMLCommon > *:last-child:is(iframe) {\n    background-color: ",";\n  }\n\n  ::-webkit-scrollbar-corner {\n    ",";\n  }\n  \n  /* Various gutter / line number styles. */\n  .CodeMirror-gutter.CodeMirror-linenumbers {\n    background: transparent !important;\n  }\n\n  "," .CodeMirror-gutters {\n    padding-right: 4px;\n    border-right: 1px solid ",";\n    /* Make it so scroll bar gutter doesn't jitter on horizontal move (default absolute). */\n    position: fixed !important;\n    left: 0 !important;\n  }\n\n  "," .CodeMirror-linenumber {\n    margin-left: -8px; /* Line numbers will bleed into the script. */\n  }\n\n  .CodeMirror-hscrollbar {\n    cursor: default;\n  }\n\n  .CodeMirror-gutters {\n    background: ",";\n    border-right: ",";\n  }\n\n  /* General cell modifications (padding and colors). */\n  .jp-Notebook {\n    padding: 12px 16px !important;\n    font-family: 'Roboto Mono', monospace !important;\n    font-size: 14px !important;\n    line-height: 20px !important;\n    font-weight: 400;\n    overflow: auto;\n  }\n\n  .jp-Notebook .cm-editor {\n    background: ",";\n    font-family: 'Roboto Mono', monospace !important;\n\n    padding-left: 10px !important;\n    padding-right: 10px !important;\n  }\n\n  .jp-InputPrompt {\n    font-family: \"Source Code Pro\", monospace;\n    flex: 0 0 var(--jp-cell-prompt-width)\n  }\n\n  .jp-InputArea {\n    display: flex !important;\n    flex-direction: row !important;\n  }\n\n  .jp-InputArea-editor {\n    flex: 1 1 auto;\n    display: block;\n    box-shadow: none !important;\n    background-color: ",";\n  }\n\n  .jp-WindowedPanel-viewport {\n    background: ",";\n    margin-top: 0 !important;\n    box-shadow: none !important\n  }\n\n  .jp-OutputArea-promptOverlay {\n    display: none;\n  }\n\n  /*\n  Hack to prevent auto-zoom behaviors on mobile browsers. These textarea\n  elements receive keystrokes and focus, but are not visible to the user. If\n  font-size is large enough, these mobile browsers will not zoom. See\n  b/271131560 for details.\n  */\n  .jp-Notebook .cm-editor textarea {\n    font-size: 16px !important;\n  }\n\n  .jp-WindowedPanel-window {\n    background: ",";\n  }\n\n  .jp-WindowedPanel-outer {\n    background: ",";\n  }\n\n  /** Removes unwanted padding on the outside frame of the editor. */\n  body[data-notebook='notebooks'] .jp-WindowedPanel-outer {\n    padding-right: unset !important;\n    padding-left: unset !important;\n    background: ","; \n  }\n\n  /** Reduces the spacing at the top of the cell. */\n  body[data-notebook='notebooks'] .jp-WindowedPanel-inner {\n    margin-top: unset !important;\n  }\n\n  body[data-notebook='notebooks'] .jp-Notebook.jp-mod-commandMode .jp-Cell.jp-mod-active.jp-mod-selected:not(.jp-mod-multiSelected) {\n    background: ",";\n  }\n\n  .jp-Toolbar {\n    ",";\n  }\n\n   .jp-SideBar.p-TabBar {\n    ",";\n  }\n\n  \n    .jp-SideBar .p-TabBar-tab:not(.p-mod-current) { \n    ",";\n\n    &:hover {\n      ",";\n    }\n  }\n\n  .jp-SideBar .p-TabBar-tab.p-mod-current { \n    ",";\n  }\n\n  /* Adjust cell margins responsively. */\n  .jp-Notebook .jp-Cell {\n    background: ",";\n    @media "," {\n      margin-left: ",";\n      margin-right: ",";\n    }\n\n    @media "," {\n      margin-left: ",";\n      margin-right: ",";\n    }\n\n    @media "," {\n      margin-left: ",";\n      margin-right: ",";\n    }\n  }\n\n  /* Adjust input prompt styles. */\n  .jp-Notebook .jp-Cell .jp-InputPrompt {\n    cursor: pointer;\n    max-width: 48px !important;\n    display: flex !important;\n    flex-flow: row nowrap !important;\n    justify-content: center !important;\n    color: ","; \n\n  }\n  .jp-Notebook.jp-mod-commandMode .jp-Cell.jp-mod-selected {\n    background: ",";\n  }\n\n  .jp-Notebook.jp-mod-commandMode .jp-Cell.jp-mod-multiSelected {\n    background: ",";\n  }\n\n  /*** CONTEXT MENU ***/\n\n  /* Context menu styles. */\n  .lm-Widget.lm-Menu {\n    border-radius: 0 0 8px 8px;\n  }\n\n  /* Context menu item styles. */\n  li.lm-Menu-item {\n    width: 320px;\n    padding: 0;\n    line-height: 48px;\n    min-height: 0;\n    margin-top: 0 !important;\n  }\n\n  /* Hide 'Show Diagnostics Panel' from LSP extension. */\n  li.lm-Menu-item[data-command='lsp:show-diagnostics-panel'] {\n    display: none;\n  }\n\n  /* Hide 'Jump to Definition' from LSP extension. */\n  li.lm-Menu-item[data-command='lsp:jump-to-definition'] {\n    display: none;\n  }\n\n  /* Hide 'Jump to Reference' from LSP extension. */\n  li.lm-Menu-item[data-command='lsp:jump-to-reference'] {\n    display: none;\n  }\n\n  /* Context menu divider styles. */\n  .lm-Menu-item[data-type='separator'] > div::after {\n    border-top: ",";\n  }\n\n  /*** NAV REMOVAL ***/\n\n  /* Hide top menu bar / logo. */\n  div#top-panel-wrapper {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n    display: none;\n  }\n\n  div#menu-panel-wrapper {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n    display: none;\n  }\n\n  /* Hide left sidebar. */\n  .lm-Widget.lm-TabBar.p-TabBar.jp-SideBar.jp-mod-left.lm-BoxPanel-child.p-BoxPanel-child {\n    display: none;\n  }\n\n  /*** EXPAND / COLLAPSE ***/\n  /* Override Jupyter styling that makes collapse bars unclickable. */\n  .jp-Notebook-cell:not(:first-child)::before,\n  .jp-Notebook-cell:not(:first-child)::after {\n    content: unset !important;\n  }\n\n  .jp-Placeholder {\n    display: flex !important;\n    flex-direction: row !important;\n    flex: 1 1 auto !important;\n  }\n\n  .jp-Placeholder-content {\n    display: flex;\n    flex: 1 1 auto;\n    flex-flow: row nowrap;\n    align-items: center;\n    height: 35px !important;\n    font-size: 14px;\n    font-style: normal;\n    font-weight: 700;\n    line-height: 20px;\n    letter-spacing: 0px;\n    border: none !important;\n    background: transparent !important;\n    cursor: pointer;\n    color: "," !important;\n  }\n\n  .jp-PlaceholderText {\n    color: "," !important;\n    font-family: Inter, sans-serif;\n  }\n\n  /* Hide ellipses. */\n  .jp-MoreHorizIcon {\n    display: none !important;\n  }\n\n  .jp-Placeholder-content:before {\n    position: absolute;\n    visibility: visible;\n    top: 0;\n    left: 0;\n    width: 48px;\n    height: 100%;\n    display: flex;\n    flex-flow: row nowrap;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    content: ",";\n  }\n\n    /* Collapsers (left gutter). General styles. */\n  .jp-Notebook .jp-Cell.jp-mod-active .jp-Collapser {\n    border-radius: 8px 0 0 8px;\n    cursor: pointer;\n    background: ",";\n    }\n    .jp-Notebook .jp-Cell:not(.jp-mod-active) .jp-Collapser:hover {\n      background: ",";\n    }\n\n    \n  .jp-Placeholder-prompt.jp-OutputPrompt {\n    max-width: 48px;\n  }\n\n  .lm-Widget.jp-OutputPrompt.jp-OutputArea-prompt {\n    max-width: 48px;\n  }\n\n  .jp-OutputPrompt {\n    flex: 0 0 var(--jp-cell-prompt-width)\n  }\n\n  /* Cell header and footer both need to allow content to spill into next cell (hover buttons). */\n  .jp-CellHeader {\n    overflow: visible;\n  }\n\n  .jp-CellFooter {\n    height: 32px !important;\n    overflow: visible !important;\n  }\n\n  /* Make the JupyterLab find tool visible. */\n  .lm-Widget.jp-DocumentSearch-overlay {\n    position: fixed;\n    min-width: 480px;\n    right: 0;\n    top: 0 !important;\n  }\n\n  /*** JUPYTER WIDGETS ***/\n  .lm-Widget.jupyter-widgets,   \n  .lm-Widget.jupyter-widgets > .widget-input  {\n    font-family: Inter, sans-serif;\n    font-size: 14px;\n    line-height: 20px;\n  }\n\n  .lm-Widget.jupyter-widgets > .widget-label {\n    font-size: 16px;\n    font-weight: 600;\n    line-height: 24px;\n    margin-bottom: 8px;\n    text-align: left;\n    width: fit-content;\n  }\n\n  .lm-Widget.jupyter-widgets > .widget-input {\n    border-color: ",";\n    border-radius: ",";\n\n    &:focus {\n      border-color: ",";\n    }\n  }\n\n  .lm-Widget.jupyter-widgets.widget-textarea {\n    align-items: flex-start;\n    display: flex;\n    flex-direction: column;\n    height: 150px;\n    width: calc(100% - 4px);\n  }\n\n  .lm-Widget.jupyter-widgets.widget-button {\n    background-color: ",";\n    border-radius: ",";\n    color: ",";\n    font-weight: 700;\n    height: 36px;\n    margin-bottom: 12px;\n    margin-top: 12px;\n    padding-left: 24px;\n    padding-right: 24px;\n\n    &:focus, &:active {\n      border: 1px solid ",';\n      outline: none;\n    }\n  }\n  \n  /*** DRAG ***/\n\n  .lm-mod-drag-image.p-mod-drag-image:before {\n    visibility: visible;\n    position: absolute;\n    box-sizing: border-box;\n    left: 0;\n    top: 0;\n    width: 8px;\n    height: 100%;\n    margin-left: -8px;\n    border-radius: 8px 0px 0px 8px;\n    content: " ";\n    background: ',";\n\n  }\n\n  .lm-mod-drag-image.p-mod-drag-image {\n    box-sizing: border-box;\n    border: 0;\n    margin-left: -24px;\n    margin-top: -28px;\n    height: auto;\n    padding: 0;\n    cursor: move !important;\n  }\n\n  .jp-dragImage.jp-dragImage-singlePrompt {\n    box-sizing: border-box;\n    border: 0;\n    border-radius: 0 8px 8px 0;\n    height: 56px;\n    width: auto;\n    cursor: move !important;\n    ",";\n   background: ",';\n\n  }\n\n    \n  /* Hide the original input prompt: "[]:" */\n  span.jp-dragImage-prompt {\n    visibility: hidden;\n    position: relative;\n    box-sizing: border-box;\n    width: 48px;\n    min-width: 48px;\n    overflow: hidden;\n    margin: 0;\n    cursor: move !important;\n  }\n\n  /* Replacement input prompt. */\n  span.jp-dragImage-prompt:after {\n    visibility: visible;\n    position: absolute;\n    box-sizing: border-box;\n    top: 0;\n    left: 0;\n    width: 48px !important;\n    max-width: 48px !important;\n    margin: 0;\n    padding: 5px;\n    display: flex !important;\n    flex: 0 0 48px;\n    flex-flow: row nowrap !important;\n    justify-content: center !important;\n    text-align: center;\n    cursor: move !important;\n    content: ',";\n  \n  }\n\n  .jp-dragImage span.jp-dragImage-content {\n    box-sizing: content-box;\n    border-radius: 8px;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    max-width: 205px;\n    width: auto;\n    height: 30px;\n    padding: 12px 16px;\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n    margin-left: 0 !important;\n    margin-right: 0 !important;\n    font-family: 'Roboto Mono', monospace !important;\n    font-size: 14px !important;\n    line-height: 20px !important;\n    background: "," !important;\n    border: 1px solid "," !important;\n  }\n\n    \n  /* Override the cursor universally when in dragging state. */\n  body.lm-mod-override-cursor.p-mod-override-cursor {\n    cursor: move !important;\n  }\n\n  /* Set the drop border color to Kaggle blue. */\n  .jp-mod-dropTarget {\n    border-top-color: #20BEFF !important;\n  }\n\n  /* Hide the normal cell during drag. */\n  .jp-mod-dropSource {\n    display: none !important;\n  }\n\n  /*** MIRRORMARK ***/\n\n  /* Add margin to bottom of markdown cell to account for markdown toolbar. */\n  .jp-MarkdownCell.jp-Notebook-cell.jp-mod-active.jp-mod-selected .CodeMirror.cm-editor.CodeMirror-wrap {\n    margin-bottom: 40px;\n  }\n\n  /* Fix the markdown toolbar. */\n  body .mirrormark-toolbar {\n    position: absolute;\n    height: 40px;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    z-index: 99;\n    cursor: default;\n  }\n\n  .mirrormark-toolbar {\n    border: 0;\n    background: ",";\n    border-top: 1px solid ",";\n    color: ",";\n    display: flex;\n    margin-top: 0;\n    margin-bottom: 0;\n    padding-left: 0;\n    padding-right: 0;\n    border-top-right-radius: 4px;\n  }\n\n  .mirrormark-toolbar li a {\n    color: ",";\n\n    &:hover {\n      color: ",";\n      background: ",";\n    }\n    background-color: ",';\n    cursor: pointer;\n    display: block;\n    font-size: 16px;\n    height: 40px;\n    line-height: 40px;\n    text-align: center;\n    transition: color .2s linear;\n    width: 40px !important;\n  }\n\n  /* Following styles are mirrormark (markdown cells). */\n  .cm-s-mirrormark .cm-m-markdown {\n    color: #000;\n    font-family: sans-serif;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-header {\n    font-family: Menlo, Consolas, Monaco, \'Andale Mono\', monospace;\n    font-weight: bold;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-header-1 {\n    font-size: 28px;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-header-2 {\n    font-size: 22px;\n    /*\n    font-size: 18px;\n    */\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-quote {\n    color: #888;\n    background-color: rgba(128, 128, 128, 0.05);\n    padding: 5px;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-quote,\n  .cm-s-mirrormark .cm-m-markdown.cm-string {\n    color: #888;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-tag,\n  .cm-s-mirrormark .cm-m-markdown.cm-link {\n    color: #444;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-comment {\n    color: #a50;\n    font-family: Menlo, Consolas, Monaco, \'Andale Mono\', monospace;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-m-xml,\n  .cm-s-mirrormark .cm-m-markdown.cm-bracket {\n    color: #170;\n    font-family: inherit;\n  }\n  .cm-s-mirrormark.CodeMirror.CodeMirror-has-preview .CodeMirror-scroll {\n    display: none;\n  }\n  .cm-s-mirrormark.CodeMirror.CodeMirror-has-preview .CodeMirror-preview {\n    display: block;\n  }\n  .cm-s-mirrormark.CodeMirror .CodeMirror-preview {\n    display: none;\n    /* This was copy pasted from mirrormark repository with important. */\n    height: auto !important;\n    /* This was copy pasted from mirrormark repository with important. */\n    overflow: visible !important;\n    padding: 30px 4%;\n    box-sizing: border-box;\n    font-family: sans-serif;\n  }\n  .cm-s-mirrormark.CodeMirror .CodeMirror-preview h1,\n  .cm-s-mirrormark.CodeMirror .CodeMirror-preview h2,\n  .cm-s-mirrormark.CodeMirror .CodeMirror-preview h3 {\n    font-family: Menlo, Consolas, Monaco, \'Andale Mono\', monospace;\n  }\n  .cm-s-mirrormark.CodeMirror .CodeMirror-preview pre,\n  .cm-s-mirrormark.CodeMirror .CodeMirror-preview code {\n    font-family: Menlo, Consolas, Monaco, \'Andale Mono\', monospace;\n  }\n  .cm-s-mirrormark.CodeMirror .CodeMirror-fullscreen .CodeMirror-preview {\n    /* This was copy pasted from mirrormark repository with important. */\n    height: 100% !important;\n    /* This was copy pasted from mirrormark repository with important. */\n    overflow: scroll !important;\n  }\n  .mirrormark-toolbar li > a {\n    display: inline-block;\n    /*\n    font-family: normal normal normal 14px/1 FontAwesome;\n    */\n    font-size: inherit;\n    text-rendering: auto;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    transform: translate(0, 0);\n  }\n  .mirrormark-toolbar li > a.pull-left {\n    margin-right: .3em;\n  }\n  .mirrormark-toolbar li > a.pull-right {\n    margin-left: .3em;\n  }\n  .mirrormark-toolbar .bold a:before {\n    content: "\f032";\n  }\n  .mirrormark-toolbar .italicize a:before {\n    content: "\f033";\n  }\n  .mirrormark-toolbar .blockquote a:before {\n    content: "\f10d";\n  }\n  .mirrormark-toolbar .strikethrough a:before {\n    content: "\f0cc";\n  }\n  .mirrormark-toolbar .link a:before {\n    content: "\f0c1";\n  }\n  .mirrormark-toolbar .image a:before {\n    content: "\f03e";\n  }\n  .mirrormark-toolbar .unorderedList a:before {\n    content: "\f03a";\n  }\n  .mirrormark-toolbar .orderedList a:before {\n    content: "\f0cb";\n  }\n  .mirrormark-toolbar .fullScreen a:before {\n    content: "\f065";\n  }\n  .mirrormark-toolbar .preview a:before {\n    content: "\f15b";\n  }\n  .cm-s-mirrormark.CodeMirror-fullscreen .mirrormark-toolbar .fullScreen a:before {\n    content: "\f066";\n  }\n  .cm-s-mirrormark.CodeMirror-has-preview .mirrormark-toolbar .preview a:before {\n    content: "\f016";\n  }\n  /* Toolbar Theme */\n      .mirrormark-toolbar li {\n    display: inline-block;\n    position: relative;\n    z-index: 1;\n  }\n  .mirrormark-toolbar li.fullScreen,\n  .mirrormark-toolbar li.preview {\n    display: none; /* added by RM to hide toolbar item */\n    float: right;\n  }\n  .mirrormark-toolbar li.has-nested:after {\n    color: #888;\n    position: absolute;\n    bottom: 3px;\n    right: 3px;\n    font-size: 11px;\n    transform: scale(1.3, 1);\n  }\n  .mirrormark-toolbar li:hover a,\n  .mirrormark-toolbar li a:hover,\n  .mirrormark-toolbar li:hover.has-nested:after {\n    color: #000;\n    text-decoration: none;\n  }\n  .mirrormark-toolbar li:hover ul {\n    display: block;\n  }\n  .mirrormark-toolbar li ul {\n    background: #e5e5e5;\n    display: none;\n    position: absolute;\n    top: 41px;\n    width: 150px;\n    z-index: 1000;\n  }\n  .mirrormark-toolbar li ul li {\n    float: none;\n    width: 100%;\n  }\n  .mirrormark-toolbar li ul li a {\n    background: transparent;\n    /* This was copy pasted from mirrormark repository with important. */\n    color: #888 !important;\n    font-family: "Helvetica Neue", sans-serif;\n    font-size: 12px;\n    height: auto;\n    line-height: normal;\n    padding: .25rem .75rem;\n    text-align: left;\n    width: auto;\n  }\n  .mirrormark-toolbar li ul li:hover a {\n    /* This was copy pasted from mirrormark repository with important. */\n    color: black !important;\n  }\n  .cm-s-mirrormark {\n    font: 16px/1.7 Menlo, Consolas, Monaco, \'Andale Mono\', monospace;\n    box-sizing: border-box;\n    height: auto;\n    margin: auto;\n    position: relative;\n    z-index: 0;\n  }\n  .cm-s-mirrormark .CodeMirror-scroll {\n    /* This was copy pasted from mirrormark repository with important. */\n    height: auto !important;\n    /* This was copy pasted from mirrormark repository with important. */\n    overflow: visible !important;\n    padding: 30px 4%;\n    box-sizing: border-box;\n  }\n  .cm-s-mirrormark.CodeMirror-fullscreen .CodeMirror-scroll {\n    /* This was copy pasted from mirrormark repository with important. */\n    height: 100% !important;\n    /* This was copy pasted from mirrormark repository with important. */\n    overflow: scroll !important;\n  }\n  .cm-s-mirrormark pre.CodeMirror-placeholder {\n    color: #999;\n  }\n'],["\n  /* Custom CSS for Python Libraries */\n  ","\n\n  /* Scrollbars */\n  * {\n    ","\n  }\n\n  /* The JL splash screen. */\n  #jupyterlab-splash {\n    display: none !important;\n  }\n\n  /* The notebook itself. */\n  .jp-NotebookPanel {\n    position: fixed !important;\n    min-width: 100vw !important;\n    min-height: 100vh !important;\n    left: 0 !important;\n    top: 0 !important;\n    width: 100vw !important;\n    height: 100vh !important;\n  }\n\n  .jp-Notebook-footer {\n    display: none;\n  }\n\n  /* The notebook area that we are expanding. */\n  .lm-DockPanel-widget {\n    border-left: 0 !important;\n    border-top: 0 !important;\n    border-right: 0 !important;\n    border-bottom: 0 !important;\n  }\n\n  /* The JL header area (toolbar / file menu). */\n  .lm-Widget.jp-Toolbar.jp-NotebookPanel-toolbar {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n    display: none;\n  }\n\n  .lm-Widget.jp-Toolbar.jp-cell-menu.jp-cell-toolbar {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n  }\n\n  /* The JL cells area. */\n  .lm-Widget.jp-Notebook.jp-mod-scrollPastEnd.jp-NotebookPanel-notebook {\n    width: 100% !important;\n    top: 0 !important;\n    /* This div is getting an inline style with discrete height from JL. */\n    height: auto !important;\n    max-height: 100%;\n    contain: unset !important;\n    background: ",";\n  }\n\n  .cm-scroller {\n    line-height: 20px !important;\n    margin-bottom: 4px;\n    margin-right: -16px;\n    padding-bottom: 4px;\n    display: block;\n  }\n\n  .cm-line.cm-line {\n    caret-color: ",' !important;\n  }\n\n  /* (b/376709824) Fixes visual bug on Safari */\n  .cm-editor > div[aria-live="polite"]:first-of-type {\n    visibility: hidden !important;\n    position: absolute !important;\n    top: unset !important;\n  }\n\n  .cm-content {\n    border-right: 22px solid transparent;\n    && {\n      padding-top: 12px;\n      padding-bottom: 12px;\n    }\n  }\n\n  /* Editor shifts when text overflows to the right, prevent the border from becoming visible. */\n  .cm-focused {\n    && {\n      outline: none;\n    }\n  }\n\n  span.cm-matchingBracket {color: #0b0;}\n  span.cm-nonmatchingBracket {color: #a22;}\n\n  /*\n   * Override JupyterLab\'s default CodeMirror syntax token colors in dark mode.\n   * The bare @jupyterlab/codemirror defaults fail WCAG AA (4.5:1) against our\n   * dark editor background (GREY_850, #2E3033), causing the readability\n   * complaints in b/372462536. Each color below is from our carbon palette and\n   * has been verified to meet 4.5:1 contrast against #2E3033; keeping the\n   * overrides centralized here also insulates us from future JupyterLab\n   * upgrades that change the defaults out from under us.\n   */\n  ',"\n\n  /* Hide dirty marker */\n  .jp-Notebook .jp-Cell.jp-mod-dirty .jp-InputPrompt::before {\n    display: none;\n  }\n\n  /* Hide rename pop up */\n  .Toastify {\n    display: none;\n  }\n\n  /* Hide orange color on run icon */\n  &.jp-Notebook &.jp-Cell.jp-mod-dirty &.jp-InputPrompt {\n    color: ","\n  }\n\n  /* Hide dirty orange background */\n  &.jp-Notebook &.jp-Cell.jp-mod-active.jp-mod-dirty &.jp-Collapser {\n    background-color: ","\n  }\n\n  /* Hide resizer when output scroll is toggled on. */\n  .jp-CodeCell.jp-mod-outputsScrolled .jp-Cell-outputArea {\n    resize: none;\n  }\n\n  /* CodeMirror wrapping element. */\n  .lm-Widget.jp-CodeMirrorEditor.jp-Editor.jp-InputArea-editor {\n    border-radius: 8px;\n    border: 1px solid "," !important;\n  }\n\n  /* Required to make cell button hover state background not clip. */\n  .lm-Widget.jp-InputPrompt.jp-InputArea-prompt {\n    overflow: visible;\n  }\n\n  /**\n   * The next few blocks are used to style the LSP rename symbol\n   * dialog. Unfortunately, the LSP dialogs don't have a custom\n   * class, so these changes would apply to all dialogs inside the\n   * iframe. However, we aren't likely to have any other dialogs\n   * inside the iframe, so this should be fine.\n   */\n  .lm-Widget.lm-Panel.jp-Dialog-content {\n    border-radius: 20px;\n    font-family: Inter, sans-serif;\n    min-width: 500px;\n    padding: 32px;\n    resize: none;\n    background-color: ",";\n  }\n\n  .lm-Widget.jp-Dialog-header {\n    font-size: 32px;\n    font-weight: 700;\n    color: ",";\n  }\n\n  .lm-Widget.lm-Panel {\n    top: 0px !important;\n  }\n\n  /* jp-mod-styled = the input element for getting the new name */\n  .lm-Widget.jp-Input-Dialog.jp-Dialog-body > .jp-mod-styled {\n    background-color: transparent;\n    border-radius: 4px;\n    box-shadow: none;\n    height: 40px;\n    margin: 8px 0 32px 0;\n    border-color: ",";\n    &:hover {\n      border-color: ",";\n    }\n    &:focus {\n      border-color: ",";\n    }\n  }\n\n  .lm-Widget.jp-Dialog-footer > .jp-Dialog-button {\n    font-size: 14px;\n    font-weight: 700;\n    height: 36px;\n    letter-spacing: normal;\n    margin: 0;\n    outline: none;\n    padding: 0 24px;\n  }\n\n  .lm-Widget.jp-Dialog-footer > .jp-Dialog-button.jp-mod-reject {\n    background-color: transparent;\n    color: ",";\n    &:hover {\n      background-color: ",";\n    }\n  }\n\n  .lm-Widget.jp-Dialog-footer > .jp-Dialog-button.jp-mod-accept {\n    background-color: ",";\n    color: ",";\n  }\n\n  /* TODO tiff: get the hover card to show up */\n  /** Fixes styling nit on documentation hover card:\n      https://screenshot.googleplex.com/66xtLHMmnPi6gAX */\n   .lsp-signature-help > .jp-Tooltip-content * {\n    background-color: ",';\n  }\n\n  /* JupyterLab adds too much padding to end of the page, which we do not\n     want. */\n  .jp-Notebook.jp-mod-scrollPastEnd::after {\n    /* TODO(b/227634919): Add enough space to the bottom of the notebook to let\n       users click "+ Code" / "+ Markdown" actions when the snackbar is visible\n       to avoid b/196609396. We should revisit when we\'re using the global page\n       snackbar instead, which may not have this issue. */\n    min-height: 128px;\n  }\n\n  \n  .jp-Notebook, .jp-MainAreaWidget {\n    ',";\n  }\n\n  .lm-Widget.lm-Panel.lm-SplitPanel-child #main-panel {\n    contain: unset !important;\n  }\n\n  /* Scripts require fixed position spanning full width / height. */\n  "," .cm-editor {\n    position: fixed !important;\n    left: 0;\n    top: 0;\n    width: 100vw;\n    max-width: 100vw;\n    height: 100vh;\n    max-height: 100vh;\n    z-index: 999999;\n    /* Ensures padding doesn't push scrollbars out of view. */\n    box-sizing: border-box;\n    overflow: auto;\n  }\n  /** (b/377925647) Makes the iFrame background viewable when in different modes. */\n  .jp-RenderedHTMLCommon > *:last-child:is(iframe) {\n    background-color: ",";\n  }\n\n  ::-webkit-scrollbar-corner {\n    ",";\n  }\n  \n  /* Various gutter / line number styles. */\n  .CodeMirror-gutter.CodeMirror-linenumbers {\n    background: transparent !important;\n  }\n\n  "," .CodeMirror-gutters {\n    padding-right: 4px;\n    border-right: 1px solid ",";\n    /* Make it so scroll bar gutter doesn't jitter on horizontal move (default absolute). */\n    position: fixed !important;\n    left: 0 !important;\n  }\n\n  "," .CodeMirror-linenumber {\n    margin-left: -8px; /* Line numbers will bleed into the script. */\n  }\n\n  .CodeMirror-hscrollbar {\n    cursor: default;\n  }\n\n  .CodeMirror-gutters {\n    background: ",";\n    border-right: ",";\n  }\n\n  /* General cell modifications (padding and colors). */\n  .jp-Notebook {\n    padding: 12px 16px !important;\n    font-family: 'Roboto Mono', monospace !important;\n    font-size: 14px !important;\n    line-height: 20px !important;\n    font-weight: 400;\n    overflow: auto;\n  }\n\n  .jp-Notebook .cm-editor {\n    background: ",";\n    font-family: 'Roboto Mono', monospace !important;\n\n    padding-left: 10px !important;\n    padding-right: 10px !important;\n  }\n\n  .jp-InputPrompt {\n    font-family: \"Source Code Pro\", monospace;\n    flex: 0 0 var(--jp-cell-prompt-width)\n  }\n\n  .jp-InputArea {\n    display: flex !important;\n    flex-direction: row !important;\n  }\n\n  .jp-InputArea-editor {\n    flex: 1 1 auto;\n    display: block;\n    box-shadow: none !important;\n    background-color: ",";\n  }\n\n  .jp-WindowedPanel-viewport {\n    background: ",";\n    margin-top: 0 !important;\n    box-shadow: none !important\n  }\n\n  .jp-OutputArea-promptOverlay {\n    display: none;\n  }\n\n  /*\n  Hack to prevent auto-zoom behaviors on mobile browsers. These textarea\n  elements receive keystrokes and focus, but are not visible to the user. If\n  font-size is large enough, these mobile browsers will not zoom. See\n  b/271131560 for details.\n  */\n  .jp-Notebook .cm-editor textarea {\n    font-size: 16px !important;\n  }\n\n  .jp-WindowedPanel-window {\n    background: ",";\n  }\n\n  .jp-WindowedPanel-outer {\n    background: ",";\n  }\n\n  /** Removes unwanted padding on the outside frame of the editor. */\n  body[data-notebook='notebooks'] .jp-WindowedPanel-outer {\n    padding-right: unset !important;\n    padding-left: unset !important;\n    background: ","; \n  }\n\n  /** Reduces the spacing at the top of the cell. */\n  body[data-notebook='notebooks'] .jp-WindowedPanel-inner {\n    margin-top: unset !important;\n  }\n\n  body[data-notebook='notebooks'] .jp-Notebook.jp-mod-commandMode .jp-Cell.jp-mod-active.jp-mod-selected:not(.jp-mod-multiSelected) {\n    background: ",";\n  }\n\n  .jp-Toolbar {\n    ",";\n  }\n\n   .jp-SideBar.p-TabBar {\n    ",";\n  }\n\n  \n    .jp-SideBar .p-TabBar-tab:not(.p-mod-current) { \n    ",";\n\n    &:hover {\n      ",";\n    }\n  }\n\n  .jp-SideBar .p-TabBar-tab.p-mod-current { \n    ",";\n  }\n\n  /* Adjust cell margins responsively. */\n  .jp-Notebook .jp-Cell {\n    background: ",";\n    @media "," {\n      margin-left: ",";\n      margin-right: ",";\n    }\n\n    @media "," {\n      margin-left: ",";\n      margin-right: ",";\n    }\n\n    @media "," {\n      margin-left: ",";\n      margin-right: ",";\n    }\n  }\n\n  /* Adjust input prompt styles. */\n  .jp-Notebook .jp-Cell .jp-InputPrompt {\n    cursor: pointer;\n    max-width: 48px !important;\n    display: flex !important;\n    flex-flow: row nowrap !important;\n    justify-content: center !important;\n    color: ","; \n\n  }\n  .jp-Notebook.jp-mod-commandMode .jp-Cell.jp-mod-selected {\n    background: ",";\n  }\n\n  .jp-Notebook.jp-mod-commandMode .jp-Cell.jp-mod-multiSelected {\n    background: ",";\n  }\n\n  /*** CONTEXT MENU ***/\n\n  /* Context menu styles. */\n  .lm-Widget.lm-Menu {\n    border-radius: 0 0 8px 8px;\n  }\n\n  /* Context menu item styles. */\n  li.lm-Menu-item {\n    width: 320px;\n    padding: 0;\n    line-height: 48px;\n    min-height: 0;\n    margin-top: 0 !important;\n  }\n\n  /* Hide 'Show Diagnostics Panel' from LSP extension. */\n  li.lm-Menu-item[data-command='lsp:show-diagnostics-panel'] {\n    display: none;\n  }\n\n  /* Hide 'Jump to Definition' from LSP extension. */\n  li.lm-Menu-item[data-command='lsp:jump-to-definition'] {\n    display: none;\n  }\n\n  /* Hide 'Jump to Reference' from LSP extension. */\n  li.lm-Menu-item[data-command='lsp:jump-to-reference'] {\n    display: none;\n  }\n\n  /* Context menu divider styles. */\n  .lm-Menu-item[data-type='separator'] > div::after {\n    border-top: ",";\n  }\n\n  /*** NAV REMOVAL ***/\n\n  /* Hide top menu bar / logo. */\n  div#top-panel-wrapper {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n    display: none;\n  }\n\n  div#menu-panel-wrapper {\n    width: 100% !important;\n    min-height: 0 !important;\n    height: 0 !important;\n    display: none;\n  }\n\n  /* Hide left sidebar. */\n  .lm-Widget.lm-TabBar.p-TabBar.jp-SideBar.jp-mod-left.lm-BoxPanel-child.p-BoxPanel-child {\n    display: none;\n  }\n\n  /*** EXPAND / COLLAPSE ***/\n  /* Override Jupyter styling that makes collapse bars unclickable. */\n  .jp-Notebook-cell:not(:first-child)::before,\n  .jp-Notebook-cell:not(:first-child)::after {\n    content: unset !important;\n  }\n\n  .jp-Placeholder {\n    display: flex !important;\n    flex-direction: row !important;\n    flex: 1 1 auto !important;\n  }\n\n  .jp-Placeholder-content {\n    display: flex;\n    flex: 1 1 auto;\n    flex-flow: row nowrap;\n    align-items: center;\n    height: 35px !important;\n    font-size: 14px;\n    font-style: normal;\n    font-weight: 700;\n    line-height: 20px;\n    letter-spacing: 0px;\n    border: none !important;\n    background: transparent !important;\n    cursor: pointer;\n    color: "," !important;\n  }\n\n  .jp-PlaceholderText {\n    color: "," !important;\n    font-family: Inter, sans-serif;\n  }\n\n  /* Hide ellipses. */\n  .jp-MoreHorizIcon {\n    display: none !important;\n  }\n\n  .jp-Placeholder-content:before {\n    position: absolute;\n    visibility: visible;\n    top: 0;\n    left: 0;\n    width: 48px;\n    height: 100%;\n    display: flex;\n    flex-flow: row nowrap;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    content: ",";\n  }\n\n    /* Collapsers (left gutter). General styles. */\n  .jp-Notebook .jp-Cell.jp-mod-active .jp-Collapser {\n    border-radius: 8px 0 0 8px;\n    cursor: pointer;\n    background: ",";\n    }\n    .jp-Notebook .jp-Cell:not(.jp-mod-active) .jp-Collapser:hover {\n      background: ",";\n    }\n\n    \n  .jp-Placeholder-prompt.jp-OutputPrompt {\n    max-width: 48px;\n  }\n\n  .lm-Widget.jp-OutputPrompt.jp-OutputArea-prompt {\n    max-width: 48px;\n  }\n\n  .jp-OutputPrompt {\n    flex: 0 0 var(--jp-cell-prompt-width)\n  }\n\n  /* Cell header and footer both need to allow content to spill into next cell (hover buttons). */\n  .jp-CellHeader {\n    overflow: visible;\n  }\n\n  .jp-CellFooter {\n    height: 32px !important;\n    overflow: visible !important;\n  }\n\n  /* Make the JupyterLab find tool visible. */\n  .lm-Widget.jp-DocumentSearch-overlay {\n    position: fixed;\n    min-width: 480px;\n    right: 0;\n    top: 0 !important;\n  }\n\n  /*** JUPYTER WIDGETS ***/\n  .lm-Widget.jupyter-widgets,   \n  .lm-Widget.jupyter-widgets > .widget-input  {\n    font-family: Inter, sans-serif;\n    font-size: 14px;\n    line-height: 20px;\n  }\n\n  .lm-Widget.jupyter-widgets > .widget-label {\n    font-size: 16px;\n    font-weight: 600;\n    line-height: 24px;\n    margin-bottom: 8px;\n    text-align: left;\n    width: fit-content;\n  }\n\n  .lm-Widget.jupyter-widgets > .widget-input {\n    border-color: ",";\n    border-radius: ",";\n\n    &:focus {\n      border-color: ",";\n    }\n  }\n\n  .lm-Widget.jupyter-widgets.widget-textarea {\n    align-items: flex-start;\n    display: flex;\n    flex-direction: column;\n    height: 150px;\n    width: calc(100% - 4px);\n  }\n\n  .lm-Widget.jupyter-widgets.widget-button {\n    background-color: ",";\n    border-radius: ",";\n    color: ",";\n    font-weight: 700;\n    height: 36px;\n    margin-bottom: 12px;\n    margin-top: 12px;\n    padding-left: 24px;\n    padding-right: 24px;\n\n    &:focus, &:active {\n      border: 1px solid ",';\n      outline: none;\n    }\n  }\n  \n  /*** DRAG ***/\n\n  .lm-mod-drag-image.p-mod-drag-image:before {\n    visibility: visible;\n    position: absolute;\n    box-sizing: border-box;\n    left: 0;\n    top: 0;\n    width: 8px;\n    height: 100%;\n    margin-left: -8px;\n    border-radius: 8px 0px 0px 8px;\n    content: " ";\n    background: ',";\n\n  }\n\n  .lm-mod-drag-image.p-mod-drag-image {\n    box-sizing: border-box;\n    border: 0;\n    margin-left: -24px;\n    margin-top: -28px;\n    height: auto;\n    padding: 0;\n    cursor: move !important;\n  }\n\n  .jp-dragImage.jp-dragImage-singlePrompt {\n    box-sizing: border-box;\n    border: 0;\n    border-radius: 0 8px 8px 0;\n    height: 56px;\n    width: auto;\n    cursor: move !important;\n    ",";\n   background: ",';\n\n  }\n\n    \n  /* Hide the original input prompt: "[]:" */\n  span.jp-dragImage-prompt {\n    visibility: hidden;\n    position: relative;\n    box-sizing: border-box;\n    width: 48px;\n    min-width: 48px;\n    overflow: hidden;\n    margin: 0;\n    cursor: move !important;\n  }\n\n  /* Replacement input prompt. */\n  span.jp-dragImage-prompt:after {\n    visibility: visible;\n    position: absolute;\n    box-sizing: border-box;\n    top: 0;\n    left: 0;\n    width: 48px !important;\n    max-width: 48px !important;\n    margin: 0;\n    padding: 5px;\n    display: flex !important;\n    flex: 0 0 48px;\n    flex-flow: row nowrap !important;\n    justify-content: center !important;\n    text-align: center;\n    cursor: move !important;\n    content: ',";\n  \n  }\n\n  .jp-dragImage span.jp-dragImage-content {\n    box-sizing: content-box;\n    border-radius: 8px;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    max-width: 205px;\n    width: auto;\n    height: 30px;\n    padding: 12px 16px;\n    margin-top: 0 !important;\n    margin-bottom: 0 !important;\n    margin-left: 0 !important;\n    margin-right: 0 !important;\n    font-family: 'Roboto Mono', monospace !important;\n    font-size: 14px !important;\n    line-height: 20px !important;\n    background: "," !important;\n    border: 1px solid "," !important;\n  }\n\n    \n  /* Override the cursor universally when in dragging state. */\n  body.lm-mod-override-cursor.p-mod-override-cursor {\n    cursor: move !important;\n  }\n\n  /* Set the drop border color to Kaggle blue. */\n  .jp-mod-dropTarget {\n    border-top-color: #20BEFF !important;\n  }\n\n  /* Hide the normal cell during drag. */\n  .jp-mod-dropSource {\n    display: none !important;\n  }\n\n  /*** MIRRORMARK ***/\n\n  /* Add margin to bottom of markdown cell to account for markdown toolbar. */\n  .jp-MarkdownCell.jp-Notebook-cell.jp-mod-active.jp-mod-selected .CodeMirror.cm-editor.CodeMirror-wrap {\n    margin-bottom: 40px;\n  }\n\n  /* Fix the markdown toolbar. */\n  body .mirrormark-toolbar {\n    position: absolute;\n    height: 40px;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    z-index: 99;\n    cursor: default;\n  }\n\n  .mirrormark-toolbar {\n    border: 0;\n    background: ",";\n    border-top: 1px solid ",";\n    color: ",";\n    display: flex;\n    margin-top: 0;\n    margin-bottom: 0;\n    padding-left: 0;\n    padding-right: 0;\n    border-top-right-radius: 4px;\n  }\n\n  .mirrormark-toolbar li a {\n    color: ",";\n\n    &:hover {\n      color: ",";\n      background: ",";\n    }\n    background-color: ",';\n    cursor: pointer;\n    display: block;\n    font-size: 16px;\n    height: 40px;\n    line-height: 40px;\n    text-align: center;\n    transition: color .2s linear;\n    width: 40px !important;\n  }\n\n  /* Following styles are mirrormark (markdown cells). */\n  .cm-s-mirrormark .cm-m-markdown {\n    color: #000;\n    font-family: sans-serif;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-header {\n    font-family: Menlo, Consolas, Monaco, \'Andale Mono\', monospace;\n    font-weight: bold;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-header-1 {\n    font-size: 28px;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-header-2 {\n    font-size: 22px;\n    /*\n    font-size: 18px;\n    */\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-quote {\n    color: #888;\n    background-color: rgba(128, 128, 128, 0.05);\n    padding: 5px;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-quote,\n  .cm-s-mirrormark .cm-m-markdown.cm-string {\n    color: #888;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-tag,\n  .cm-s-mirrormark .cm-m-markdown.cm-link {\n    color: #444;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-comment {\n    color: #a50;\n    font-family: Menlo, Consolas, Monaco, \'Andale Mono\', monospace;\n  }\n  .cm-s-mirrormark .cm-m-markdown.cm-m-xml,\n  .cm-s-mirrormark .cm-m-markdown.cm-bracket {\n    color: #170;\n    font-family: inherit;\n  }\n 